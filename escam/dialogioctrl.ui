      <widget class="QSpinBox" name="spinBoxBoard">
       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;select PCIe board&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="whatsThis">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;When there are multiple PCIe boards connect, this controls which PCIe card is controlled by this window. This controls the parameter drvno.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="maximum">
        <number>4</number>
       </property>
      </widget>
     </item>
     <item row="1" column="2">
      <widget class="QComboBox" name="comboBoxTrigSource">
       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;trigger source of channel outputs&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="whatsThis">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Trigger source selects which signal is used to trigger the outputs of IOCtrl and shift to the next position in the sequence.&lt;/p&gt;&lt;p&gt;0 manual: Manual mode&lt;br/&gt;1 sti: Scan trigger input, controlled by sti_mode&lt;br/&gt;2 sslope: Scan trigger with sslope applied&lt;br/&gt;3 scan_gated: Scan trigger gated by block on&lt;br/&gt;4 sticnt: Scan trigger with sticnt applied&lt;br/&gt;5 sdat: Scan trigger after sdat_in_10ns&lt;br/&gt;6 sec: Scan trigger after sec_in_10ns&lt;br/&gt;7 xck: Start of XCK&lt;br/&gt;8 bti_mode: Block trigger input, controlled by bti_mode&lt;br/&gt;9 bslope: Block trigger with bslope applied&lt;br/&gt;10 bticnt: Block trigger with bticnt applied&lt;br/&gt;11 bdat: Block trigger after bdat_in_10ns&lt;br/&gt;12 bec: Block trigger after bec_in_10ns&lt;br/&gt;13 block_on: Block on signal&lt;br/&gt;14 block_on_synced: Block on signal synced to the next scan trigger&lt;br/&gt;15 unused&lt;/p&gt;&lt;p&gt;The trigger source is set by the function DLLSetStateControlRegister.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <item>
        <property name="text">
         <string>manual</string>
        </property>
       </item>
       <item>
        <property name="text">
         <string>STI</string>
        </property>
       </item>
       <item>
        <property name="text">
