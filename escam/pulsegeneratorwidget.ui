     <item row="2" column="1">
      <widget class="QLabel" name="labelSequenceOn">
       <property name="whatsThis">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Sequence represents the high / low states of the output signal. On each trigger an output signal is generated depending on the current position in the sequence. All three representations (Dec, Hex, Bin) are editing the same output sequence. The sequence is LSB first, so the first digit from the right in Bin is the first high / low state of the output signal. When the last digit is reached the sequence starts back at the LSB. Also each DLLInitMeasurement() resets the sequence cursor to the first position, so that happens every time when pressing start in the main window of Escam.&lt;/p&gt;&lt;p&gt;The sequence is set by the function DLLCamIOCtrl_setSequence.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="text">
        <string>Sequence</string>
       </property>
      </widget>
     </item>
